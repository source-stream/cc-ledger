#!/usr/bin/env bash
# ledger-disable
# Opt the current clone out: remove the .ledger.json marker and its .git/info/exclude
# line, leaving the exclude file otherwise intact.
set -eu

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
rm -f "$ROOT/.ledger.json"

if git rev-parse --git-dir >/dev/null 2>&1; then
  EXCL="$(git rev-parse --git-path info/exclude)"
  if [ -f "$EXCL" ]; then
    grep -vxF '.ledger.json' "$EXCL" > "$EXCL.tmp" 2>/dev/null || true
    mv "$EXCL.tmp" "$EXCL"
  fi
fi

echo "[cc-ledger] disabled (marker + exclude line removed)"
