{
  "version": 2,
  "groups": {
    "acme": {
      "channel": "#acme-ledger",
      "description": "Acme multi-service platform (example group)",
      "projects": {
        "web": {
          "match": ["acme-web"],
          "role": "Front-end / application code",
          "responsibility": {
            "summary": "Front-end / application code",
            "keywords": ["UI", "components", "pages", "client", "styling"]
          }
        },
        "api": {
          "match": ["acme-api"],
          "role": "Backend API service",
          "responsibility": {
            "summary": "Backend API service",
            "keywords": ["endpoints", "auth", "business logic", "data access"]
          }
        },
        "infra": {
          "match": ["acme-infra", "acme-cdk"],
          "role": "Cloud infrastructure (CDN, DNS, serverless)",
          "responsibility": {
            "summary": "Cloud infrastructure",
            "keywords": ["CDN", "DNS", "serverless", "deploy", "IAM"]
          }
        }
      }
    },
    "nomadfoods": {
      "channel": "#nomad-ledger",
      "description": "Nomad foods platform (example group): monorepo + ETL + infra. Shows the responsibility/areas fields used to route new work to the right repo.",
      "projects": {
        "nomadfoods": {
          "match": ["nomadfoods.git"],
          "role": "Customer-facing monorepo",
          "responsibility": {
            "summary": "Customer-facing web platform & content/search services",
            "keywords": ["UI", "frontend", "components", "content", "search"]
          },
          "areas": {
            "web": "Next.js storefront & pages",
            "storybook": "shared UI component library",
            "content-api": "CMS / content delivery service",
            "search-api": "product search & indexing"
          }
        },
        "nomadfoods-migration-etl": {
          "match": ["nomadfoods-migration-etl"],
          "role": "Data ETL pipeline",
          "responsibility": {
            "summary": "Data import & load pipelines",
            "keywords": ["data import", "ETL", "ingestion", "batch load", "source data"]
          }
        },
        "nomadfoods-cdk": {
          "match": ["nomadfoods-cdk"],
          "role": "Infrastructure as code",
          "responsibility": {
            "summary": "AWS CDK infrastructure & deploy pipelines",
            "keywords": ["infra", "CDK", "IAM", "deploy", "AWS resources"]
          }
        }
      }
    },
    "example-single": {
      "channel": "#example-ledger",
      "description": "A single-project group (example)",
      "projects": {
        "app": {
          "match": ["example-app"],
          "role": "Application"
        }
      }
    },
    "example-monorepo": {
      "channel": "#monorepo-ledger",
      "description": "A monorepo group (example): one git remote, many sub-apps. Because match is tested only against the remote URL, every sub-app shares the same match and is selected by the marker's explicit `project` field — not by match. A monorepo clone that omits `project` resolves to `unknown` by design, so always set it (e.g. `ledger-enable example-monorepo monorepo-frontend`).",
      "projects": {
        "monorepo-frontend": {
          "match": ["monorepo.git"],
          "role": "Frontend (monorepo: apps/frontend)"
        },
        "monorepo-content-api": {
          "match": ["monorepo.git"],
          "role": "Content API (monorepo: apps/content-api)"
        },
        "monorepo-search-api": {
          "match": ["monorepo.git"],
          "role": "Search API (monorepo: apps/search-api)"
        }
      }
    }
  }
}
