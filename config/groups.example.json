{
  "version": 1,
  "groups": {
    "acme": {
      "channel": "#acme-ledger",
      "description": "Acme multi-service platform (example group)",
      "projects": {
        "web": {
          "match": ["acme-web"],
          "role": "Front-end / application code"
        },
        "api": {
          "match": ["acme-api"],
          "role": "Backend API service"
        },
        "infra": {
          "match": ["acme-infra", "acme-cdk"],
          "role": "Cloud infrastructure (CDN, DNS, serverless)"
        }
      }
    },
    "example-single": {
      "channel": "#example-ledger",
      "description": "A single-project group (example)",
      "projects": {
        "app": {
          "match": ["example-app"],
          "role": "Application"
        }
      }
    },
    "example-monorepo": {
      "channel": "#monorepo-ledger",
      "description": "A monorepo group (example): one git remote, many sub-apps. Because match is tested only against the remote URL, every sub-app shares the same match and is selected by the marker's explicit `project` field — not by match. A monorepo clone that omits `project` resolves to `unknown` by design, so always set it (e.g. `ledger-enable example-monorepo monorepo-frontend`).",
      "projects": {
        "monorepo-frontend": {
          "match": ["monorepo.git"],
          "role": "Frontend (monorepo: apps/frontend)"
        },
        "monorepo-content-api": {
          "match": ["monorepo.git"],
          "role": "Content API (monorepo: apps/content-api)"
        },
        "monorepo-search-api": {
          "match": ["monorepo.git"],
          "role": "Search API (monorepo: apps/search-api)"
        }
      }
    }
  }
}
